{
  "platforms": {
    "web": {
      "supported": true,
      "build": {
        "command": "npm run build"
      },
      "test": {
        "command": "npm test"
      },
      "runtime": {
        "fastSkipsBuild": true
      }
    },
    "ios": {
      "supported": true,
      "build": {
        "scheme": "XenixCapTodoPlugin",
        "derivedDataPath": "./ios/build"
      },
      "runtime": {
        "simulatorName": "iPhone 17",
        "deviceType": "com.apple.CoreSimulator.SimDeviceType.iPhone-17",
        "runtimeId": "com.apple.CoreSimulator.SimRuntime.iOS-26-4"
      },
      "test": {
        "only": "-only-testing:TodoPluginTests"
      }
    },
    "android": {
      "supported": true,
      "build": {
        "gradleCommand": "./android/gradlew -p android",
        "task": "assembleDebug"
      },
      "test": {
        "mode": "unit",
        "command": "./android/gradlew -p android test"
      }
    }
  }
}
