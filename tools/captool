#!/bin/bash

set -u

# =========================================
# Captool (v0.1)
# =========================================
# 角色:
#   repo-local 正式工具入口。
#   入口只負責：
#   - 載入工具模組
#   - CLI 命令分派
#   - 測試主流程組裝
#
# 目前支援:
#   ./tools/captool test [all|web|ios|android] [options]
#   ./tools/captool clean [artifacts|global-caches]
#   ./tools/captool doctor
#   ./tools/captool report [latest|<file>]
#   ./tools/captool help
#
# 內部骨架:
#   tools/lib/common.sh           共用 helper
#   tools/lib/cli.sh              CLI 參數解析與命令分派
#   tools/lib/summary.sh          結果摘要與 report 初始化
#   tools/lib/doctor.sh           doctor 子命令
#   tools/lib/report.sh           report 子命令
#   tools/lib/clean.sh            clean 子命令與 artifact 清理
#   tools/lib/test.sh             測試主流程共用邏輯
#   tools/lib/platform-*.sh       各平台執行細節
# =========================================

COMMAND="test"
PLATFORM="all"
DEVICE=""
NO_CLOSE=0
LOG_FILE=""
REPORT=0
REPORT_FILE=""
FAILURES=0
FAST_MODE=0
KEEP_ARTIFACTS=0
CURRENT_PLATFORM_SUMMARY=""
CURRENT_PLATFORM_FAILURE=""
WEB_RESULT="SKIPPED"
IOS_RESULT="SKIPPED"
ANDROID_RESULT="SKIPPED"

WEB_BUILD_CMD="npm run build"
CONTRACT_TEST_CMD="${CONTRACT_TEST_CMD:-npm test}"

IOS_SCHEME="${IOS_SCHEME:-XenixCapTodoPlugin}"
IOS_DERIVED_DATA="${IOS_DERIVED_DATA:-./ios/build}"
IOS_SIMULATOR_NAME="${IOS_SIMULATOR_NAME:-iPhone 17}"
IOS_TEST_ONLY="${IOS_TEST_ONLY:--only-testing:TodoPluginTests}"
IOS_TEST_BUNDLE_PATH="${IOS_TEST_BUNDLE_PATH:-$IOS_DERIVED_DATA/Build/Products/Debug-iphonesimulator/TodoPluginTests.xctest/TodoPluginTests}"

ANDROID_GRADLE_CMD="${ANDROID_GRADLE_CMD:-./android/gradlew -p android}"
ANDROID_TEST_CMD="${ANDROID_TEST_CMD:-$ANDROID_GRADLE_CMD test}"

IOS_STARTED_BY_SCRIPT=0
IOS_ACTIVE_DEVICE=""
IOS_ACTIVE_DESTINATION=""
REPORT_TARGET="latest"
CAPTOOL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$CAPTOOL_DIR/lib/common.sh"
source "$CAPTOOL_DIR/lib/cli.sh"
source "$CAPTOOL_DIR/lib/commands/doctor.sh"
source "$CAPTOOL_DIR/lib/commands/report.sh"
source "$CAPTOOL_DIR/lib/commands/clean.sh"
source "$CAPTOOL_DIR/lib/summary.sh"
source "$CAPTOOL_DIR/lib/commands/test.sh"
source "$CAPTOOL_DIR/lib/platforms/web.sh"
source "$CAPTOOL_DIR/lib/platforms/ios.sh"
source "$CAPTOOL_DIR/lib/platforms/android.sh"
ensure_tool_output_dirs
parse_command "$@"
dispatch_non_test_commands
parse_test_args
initialize_report_file

print_test_header

if [[ "$PLATFORM" == "all" || "$PLATFORM" == "web" ]]; then
  run_platform "Web" run_web_tests WEB_RESULT
fi

if [[ "$PLATFORM" == "all" || "$PLATFORM" == "ios" ]]; then
  run_platform "iOS" run_ios_tests IOS_RESULT
fi

if [[ "$PLATFORM" == "all" || "$PLATFORM" == "android" ]]; then
  run_platform "Android" run_android_tests ANDROID_RESULT
fi

print_test_footer

exit "$FAILURES"
