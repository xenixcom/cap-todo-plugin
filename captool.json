{
  "platforms": {
    "web": {
      "supported": true,
      "build": {
        "command": "npm run build"
      }
    },
    "ios": {
      "supported": true,
      "build": {
        "scheme": "XenixCapTodoPlugin",
        "derivedDataPath": "./ios/build"
      },
      "runtime": {
        "simulatorName": "iPhone 17"
      },
      "test": {
        "only": "-only-testing:TodoPluginTests"
      }
    },
    "android": {
      "supported": true,
      "build": {
        "gradleCommand": "./android/gradlew -p android"
      },
      "test": {
        "command": "./android/gradlew -p android test"
      }
    }
  }
}
