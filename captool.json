{
  "platforms": {
    "web": {
      "supported": true,
      "buildCommand": "npm run build"
    },
    "ios": {
      "supported": true,
      "scheme": "XenixCapTodoPlugin",
      "derivedDataPath": "./ios/build",
      "simulatorName": "iPhone 17",
      "testOnly": "-only-testing:TodoPluginTests"
    },
    "android": {
      "supported": true,
      "gradleCommand": "./android/gradlew -p android",
      "testCommand": "./android/gradlew -p android test"
    }
  }
}
