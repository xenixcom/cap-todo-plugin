#!/bin/bash

set -u

# =========================================
# Captool (v0.5.2)
# =========================================
# 角色:
#   repo-local 正式工具入口。
#   入口只負責：
#   - 載入工具模組
#   - CLI 命令分派
#   - 測試主流程組裝
#
# 目前支援:
#   ./tools/captool test [all|web|ios|android] [options]
#   ./tools/captool clean [artifacts|global-caches]
#   ./tools/captool doctor
#   ./tools/captool report [latest|<file>]
#   ./tools/captool help
#
# 內部骨架:
#   tools/lib/common.sh           共用 helper
#   tools/lib/cli.sh              CLI 參數解析與命令分派
#   tools/lib/summary.sh          結果摘要與 report 初始化
#   tools/lib/commands/*          命令層
#   tools/lib/platforms/*         各平台執行細節
#
# 保留方向:
#   future outdated / update / upgrade
#   應分開考慮 scripts 與 template 的相容性
# =========================================

CAPTOOL_VERSION="0.5.2"
COMMAND="test"
PLATFORM="all"
DEVICE=""
NO_CLOSE=0
LOG_FILE=""
REPORT=0
REPORT_FILE=""
FAILURES=0
FAST_MODE=0
KEEP_ARTIFACTS=0
CURRENT_PLATFORM_SUMMARY=""
CURRENT_PLATFORM_FAILURE=""
WEB_RESULT="SKIPPED"
IOS_RESULT="SKIPPED"
ANDROID_RESULT="SKIPPED"

IOS_STARTED_BY_SCRIPT=0
IOS_ACTIVE_DEVICE=""
IOS_ACTIVE_DESTINATION=""
REPORT_TARGET="latest"
CAPTOOL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CAPTOOL_ROOT="$(cd "$CAPTOOL_DIR/.." && pwd)"
CAPTOOL_CONFIG="${CAPTOOL_CONFIG:-$CAPTOOL_ROOT/captool.json}"
CAPTOOL_LOCAL_CONFIG="${CAPTOOL_LOCAL_CONFIG:-$CAPTOOL_ROOT/captool.local.json}"
source "$CAPTOOL_DIR/lib/common.sh"
source "$CAPTOOL_DIR/lib/cli.sh"
source "$CAPTOOL_DIR/lib/commands/doctor.sh"
source "$CAPTOOL_DIR/lib/commands/report.sh"
source "$CAPTOOL_DIR/lib/commands/clean.sh"
source "$CAPTOOL_DIR/lib/summary.sh"
source "$CAPTOOL_DIR/lib/commands/test.sh"
source "$CAPTOOL_DIR/lib/platforms/web.sh"
source "$CAPTOOL_DIR/lib/platforms/ios.sh"
source "$CAPTOOL_DIR/lib/platforms/android.sh"

WEB_BUILD_CMD="${WEB_BUILD_CMD:-$(read_captool_config_with_local_override "platforms.web.build.command" || echo "npm run build")}"
WEB_TEST_CMD="${WEB_TEST_CMD:-$(read_captool_config_with_local_override "platforms.web.test.command" || echo "npm test")}"
WEB_FAST_SKIP_BUILD="${WEB_FAST_SKIP_BUILD:-$(read_captool_config_with_local_override "platforms.web.runtime.fastSkipsBuild" || echo "true")}"
CONTRACT_TEST_CMD="${CONTRACT_TEST_CMD:-$WEB_TEST_CMD}"

IOS_SCHEME="${IOS_SCHEME:-$(read_captool_config_with_local_override "platforms.ios.build.scheme" || echo "XenixCapTodoPlugin")}"
IOS_DERIVED_DATA="${IOS_DERIVED_DATA:-$(read_captool_config_with_local_override "platforms.ios.build.derivedDataPath" || echo "./ios/build")}"
IOS_SIMULATOR_NAME="${IOS_SIMULATOR_NAME:-$(read_captool_config_with_local_override "platforms.ios.runtime.simulatorName" || echo "iPhone 17")}"
IOS_SIMULATOR_DEVICE_TYPE="${IOS_SIMULATOR_DEVICE_TYPE:-$(read_captool_config_with_local_override "platforms.ios.runtime.deviceType" || echo "com.apple.CoreSimulator.SimDeviceType.iPhone-17")}"
IOS_SIMULATOR_RUNTIME_ID="${IOS_SIMULATOR_RUNTIME_ID:-$(read_captool_config_with_local_override "platforms.ios.runtime.runtimeId" || echo "com.apple.CoreSimulator.SimRuntime.iOS-26-4")}"
IOS_TEST_ONLY="${IOS_TEST_ONLY:-$(read_captool_config_with_local_override "platforms.ios.test.only" || echo "-only-testing:TodoPluginTests")}"
IOS_TEST_BUNDLE_PATH="${IOS_TEST_BUNDLE_PATH:-$IOS_DERIVED_DATA/Build/Products/Debug-iphonesimulator/TodoPluginTests.xctest/TodoPluginTests}"

ANDROID_GRADLE_CMD="${ANDROID_GRADLE_CMD:-$(read_captool_config_with_local_override "platforms.android.build.gradleCommand" || echo "./android/gradlew -p android")}"
ANDROID_BUILD_TASK="${ANDROID_BUILD_TASK:-$(read_captool_config_with_local_override "platforms.android.build.task" || echo "assembleDebug")}"
ANDROID_TEST_MODE="${ANDROID_TEST_MODE:-$(read_captool_config_with_local_override "platforms.android.test.mode" || echo "unit")}"
ANDROID_TEST_CMD="${ANDROID_TEST_CMD:-$(read_captool_config_with_local_override "platforms.android.test.command" || echo "$ANDROID_GRADLE_CMD test")}"

ensure_tool_output_dirs
parse_command "$@"
dispatch_non_test_commands
parse_test_args
initialize_report_file

print_test_header

if [[ "$PLATFORM" == "all" || "$PLATFORM" == "web" ]]; then
  run_or_resolve_platform "web" "Web" run_web_tests WEB_RESULT
fi

if [[ "$PLATFORM" == "all" || "$PLATFORM" == "ios" ]]; then
  run_or_resolve_platform "ios" "iOS" run_ios_tests IOS_RESULT
fi

if [[ "$PLATFORM" == "all" || "$PLATFORM" == "android" ]]; then
  run_or_resolve_platform "android" "Android" run_android_tests ANDROID_RESULT
fi

print_test_footer

exit "$FAILURES"
